# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:port/database"

# Secret used to sign session JWTs — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-a-long-random-string"

# Cloudflare R2 (S3-compatible) — media & document storage.
# Create a bucket + an R2 API token (Object Read & Write), then fill these in.
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="r2-access-key-id"
R2_SECRET_ACCESS_KEY="r2-secret-access-key"
R2_BUCKET="sport-visa"
# Public base URL of the bucket (r2.dev domain or custom domain), no trailing slash.
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"
